# Example env config for invoice OCR pipelines
# Copy this to .env and then edit values for your environment.

# Models (local path or HuggingFace repo identifier)
MODEL_PATH_HEADER=
MODEL_PATH_TABLE=
MODEL_PATH_FOOTER=

# Real invoice evaluation runner
REAL_INVOICES_DIR=invoice_ocr/inference/real_invoices
GROUND_TRUTH_FILE=invoice_ocr/inference/labels/labels.json
OUTPUT_FILE=invoice_ocr/inference/results/real_test_results.json
TEMP_DIR=invoice_ocr/inference/tmp

# Service configuration (web API)
HOST=0.0.0.0
PORT=5000
DEVICE=cpu

# Optional: limit request rate
RATE_LIMIT_RPM=20
RATE_LIMIT_ENABLED=true
